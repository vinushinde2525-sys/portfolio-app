# ── Backend Environment Variables ───────────────────────────
# Copy to .env and fill in your values

PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/portfolio?retryWrites=true&w=majority

# JWT secrets — use strong random strings (min 64 chars)
JWT_SECRET=your_very_strong_jwt_secret_here_minimum_64_characters_long
JWT_REFRESH_SECRET=your_very_strong_refresh_secret_here_minimum_64_characters

# Allowed frontend origins (comma-separated for multiple)
ALLOWED_ORIGINS=http://localhost:5173,https://vinayak-portfolio.onrender.com

# Cloudinary (for image uploads) — optional
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Gmail SMTP (for contact form emails) — optional
EMAIL_USER=
EMAIL_PASS=

# Admin seed credentials
ADMIN_EMAIL=admin@vinayakshinde.dev
ADMIN_PASSWORD=ChangeThisSecurePassword123!
